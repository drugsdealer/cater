# Переменные окружения для отправки заявок в Telegram.
# На Vercel задаются в Project → Settings → Environment Variables (НЕ коммитьте реальные значения).

# Токен бота от @BotFather (пример: 123456789:AAABBB...)
TELEGRAM_BOT_TOKEN=

# ID чата, куда слать заявки (ваш личный id, id группы или канала)
TELEGRAM_CHAT_ID=
